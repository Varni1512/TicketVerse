# Docker Compose Configuration
KAFKA_BROKERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=ticketverse_redis_secret

# Database Configuration (Neon PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ticketverse
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT Security
# Ensure this is a secure, Base64-encoded string in production!
JWT_SECRET=c2VjcmV0LWtleS1mb3ItdGlja2V0dmVyc2UtYXBwbGljYXRpb24tc2hvdWxkLWJlLWxvbmctZW5vdWdo_default_local_dev_key

# Cloudinary Integration (Required for Event Service Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Services Ports (Local Development Overrides)
PORT_GATEWAY=8080
PORT_AUTH=8081
PORT_EVENT=8082
PORT_BOOKING=8083
PORT_CONTACT=8084
PORT_NOTIFICATION=8085
PORT_ANALYTICS=8086
PORT_AUDIT=8087
